{
  "name": "fiap-13soat-techchallenge-5-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @fiap-13soat/shared && npm run --workspaces --if-present build --include-workspace-root=false",
    "dev": "npm run --workspaces --if-present dev",
    "lint": "npm run --workspaces --if-present lint",
    "test": "npm run --workspaces --if-present test",
    "test:coverage": "npm run --workspaces --if-present test:coverage",
    "format": "npm run --workspaces --if-present format",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
